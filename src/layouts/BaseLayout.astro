---
import '@fontsource/playfair-display/latin-400.css';
import '@fontsource/playfair-display/latin-700.css';

import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n';
import { htmlLang, languages, ui, type Lang } from '../i18n/ui';

type SkipKey = 'skip.toMap' | 'skip.toContent';

interface Props {
  title: string;
  description?: string;
  mode?: 'app' | 'document';
  skipTarget?: { id: string; labelKey: SkipKey };
}

const {
  title,
  description: descriptionProp,
  mode = 'app',
  skipTarget = { id: 'map', labelKey: 'skip.toMap' },
} = Astro.props;
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const altLang: Lang = lang === 'fr' ? 'en' : 'fr';
const brandName = ui[lang]['site.title'];
const skipLabel = ui[lang][skipTarget.labelKey];

const baseNoSlash = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathInBase = Astro.url.pathname.startsWith(baseNoSlash)
  ? Astro.url.pathname.slice(baseNoSlash.length) || '/'
  : Astro.url.pathname;
const pathInDefaultLocale =
  lang === 'fr' ? pathInBase : pathInBase.replace(/^\/en(?=\/|$)/, '') || '/';

const altHref = getRelativeLocaleUrl(altLang, pathInDefaultLocale);
const frHref = getAbsoluteLocaleUrl('fr', pathInDefaultLocale);
const enHref = getAbsoluteLocaleUrl('en', pathInDefaultLocale);

const sectionHref =
  mode === 'app'
    ? getRelativeLocaleUrl(lang, '/aops/')
    : getRelativeLocaleUrl(lang, '/');
const sectionLabel =
  mode === 'app' ? ui[lang]['nav.browse'] : ui[lang]['nav.map'];
const brandHref = getRelativeLocaleUrl(lang, '/');

const description = descriptionProp ?? ui[lang]['site.description'];
const ogImageAlt = ui[lang]['og.image.alt'];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(`${baseNoSlash}/og-image.png`, Astro.site).href;
const faviconUrl = `${baseNoSlash}/favicon.svg`;
const appleTouchIconUrl = `${baseNoSlash}/apple-touch-icon.png`;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_GB';
const ogLocaleAlt = lang === 'fr' ? 'en_GB' : 'fr_FR';

const csp = [
  "default-src 'self'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: https://*.tile.openstreetmap.org https://tile.openstreetmap.org",
  "font-src 'self' data:",
  "connect-src 'self'",
  "base-uri 'self'",
  "form-action 'self'",
  "frame-ancestors 'none'",
].join('; ');

const noscriptMessage =
  lang === 'fr'
    ? 'Cette carte interactive a besoin de JavaScript pour fonctionner.'
    : 'This interactive map needs JavaScript to work.';
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#b85a30" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="apple-touch-icon" href={appleTouchIconUrl} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="en-GB" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={frHref} />
    <link rel="preconnect" href="https://tile.openstreetmap.org" crossorigin />
    <link rel="dns-prefetch" href="https://tile.openstreetmap.org" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Terroir" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
  </head>
  <body data-mode={mode}>
    <a href={`#${skipTarget.id}`} class="skip-link">{skipLabel}</a>
    {mode === 'app' && <h1 class="visually-hidden">{title}</h1>}
    <a class="brand-card" href={brandHref}>
      <svg class="brand-card__mark" viewBox="0 0 64 64" aria-hidden="true">
        <path
          d="M32 4 L56 18 V46 L32 60 L8 46 V18 Z"
          fill="#ffffff"
          stroke="#b85a30"
          stroke-width="3"
          stroke-linejoin="round"></path>
        <path
          d="M12 16 L52 16 L52 26 L50 26 L50 22 L34 22 L34 47 L44 47 L44 51 L20 51 L20 47 L30 47 L30 22 L14 22 L14 26 L12 26 Z"
          fill="#707a32"></path>
      </svg>
      <span class="brand-card__name">{brandName}</span>
    </a>
    <nav class="nav-card" aria-label={ui[lang]['nav.primary']}>
      <a class="nav-card__link" href={sectionHref}>{sectionLabel}</a>
      <span class="nav-card__divider" aria-hidden="true"></span>
      <a
        class="nav-card__link"
        href={altHref}
        hreflang={htmlLang[altLang]}
        lang={htmlLang[altLang]}
      >
        {languages[altLang]}
      </a>
    </nav>
    <noscript>
      <p class="noscript-message">{noscriptMessage}</p>
    </noscript>
    <div class="app">
      <slot />
    </div>
    <style is:global>
      :root {
        --color-bg: #ffffff;
        --color-cream: #faf3e7;
        --color-cream-tint: #f6ecd9;
        --color-text: #1a1a1a;
        --color-text-muted: #595959;
        --color-border: #e0e0e0;
        --color-terracotta: #b85a30;
        --color-terracotta-hover: #a04d28;
        --color-olive: #707a32;
        --color-olive-hover: #5e6a2a;
        --color-focus: var(--color-terracotta);

        --glass-bg: rgba(255, 255, 255, 0.72);
        --glass-border: rgba(255, 255, 255, 0.55);
        --glass-blur: blur(20px) saturate(1.6);

        --shadow-soft:
          0 1px 2px rgba(20, 12, 8, 0.04), 0 4px 12px rgba(20, 12, 8, 0.06);
        --shadow-elevated:
          0 1px 2px rgba(20, 12, 8, 0.05), 0 8px 24px rgba(20, 12, 8, 0.1),
          0 24px 48px rgba(20, 12, 8, 0.08);

        --font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --font-body: system-ui, -apple-system, sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      @media (prefers-reduced-motion: no-preference) {
        html {
          scroll-behavior: smooth;
        }
      }
      body {
        background: var(--color-cream);
        font-family: var(--font-body);
        color: var(--color-text);
      }
      body[data-mode='app'] {
        height: 100dvh;
        overflow: hidden;
      }
      body[data-mode='app'] .app {
        height: 100%;
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
      }
      body[data-mode='document'] {
        min-height: 100dvh;
      }
      body[data-mode='document'] .app {
        padding: 0;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        white-space: nowrap;
        border: 0;
      }

      .skip-link {
        position: fixed;
        top: 0.5rem;
        left: 0.5rem;
        z-index: 2001;
        padding: 0.625rem 1rem;
        background: var(--color-terracotta);
        color: white;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: var(--shadow-elevated);
        transform: translateY(-150%);
        transition: transform 0.15s ease;
      }
      .skip-link:focus {
        transform: translateY(0);
        outline: 2px solid white;
        outline-offset: 2px;
      }
      @media (prefers-reduced-motion: reduce) {
        .skip-link {
          transition: none;
        }
      }

      .brand-card {
        position: fixed;
        top: 1.25rem;
        left: 1.25rem;
        z-index: 1000;
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        background: var(--glass-bg);
        -webkit-backdrop-filter: var(--glass-blur);
        backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: 999px;
        padding: 0.4rem 1rem 0.4rem 0.5rem;
        box-shadow: var(--shadow-soft);
        text-decoration: none;
        transition:
          background 0.15s ease,
          box-shadow 0.15s ease;
      }
      a.brand-card:hover {
        background: rgba(255, 255, 255, 0.85);
      }
      a.brand-card:focus-visible {
        outline: 2px solid var(--color-focus);
        outline-offset: 2px;
      }
      .brand-card__mark {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.12));
      }
      .brand-card__name {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(1.125rem, 3.5vw, 1.375rem);
        color: var(--color-terracotta);
        letter-spacing: 0.005em;
        line-height: 1.1;
      }

      .nav-card {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 1002;
        background: var(--glass-bg);
        -webkit-backdrop-filter: var(--glass-blur);
        backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: 999px;
        padding: 0.25rem 0.5rem;
        box-shadow: var(--shadow-soft);
      }
      .nav-card {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
      }
      .nav-card__link {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: 0.25rem 0.75rem;
        color: var(--color-text);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 999px;
        transition: background 0.15s ease;
      }
      .nav-card__link:hover {
        background: rgba(0, 0, 0, 0.05);
      }
      .nav-card__link:focus-visible {
        outline: 2px solid var(--color-focus);
        outline-offset: 2px;
      }
      .nav-card__divider {
        width: 1px;
        align-self: stretch;
        margin: 0.375rem 0;
        background: rgba(0, 0, 0, 0.1);
      }

      .noscript-message {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2000;
        margin: 0;
        max-width: min(90vw, 28rem);
        padding: 1rem 1.25rem;
        background: white;
        border-radius: 12px;
        box-shadow: var(--shadow-elevated);
        text-align: center;
      }
    </style>
  </body>
</html>
