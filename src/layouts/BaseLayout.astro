---
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n';
import { htmlLang, languages, ui, type Lang } from '../i18n/ui';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const altLang: Lang = lang === 'fr' ? 'en' : 'fr';

// Compute the path within the default locale so the language switcher and
// hreflang links preserve the current page (works for `/`, `/en/`, future
// `/dishes/`, `/en/dishes/`, etc.).
const baseNoSlash = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathInBase = Astro.url.pathname.startsWith(baseNoSlash)
  ? Astro.url.pathname.slice(baseNoSlash.length) || '/'
  : Astro.url.pathname;
const pathInDefaultLocale =
  lang === 'fr' ? pathInBase : pathInBase.replace(/^\/en(?=\/|$)/, '') || '/';

const altHref = getRelativeLocaleUrl(altLang, pathInDefaultLocale);
const frHref = getAbsoluteLocaleUrl('fr', pathInDefaultLocale);
const enHref = getAbsoluteLocaleUrl('en', pathInDefaultLocale);

const description = ui[lang]['site.description'];
const ogImageAlt = ui[lang]['og.image.alt'];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(`${baseNoSlash}/og-image.png`, Astro.site).href;
const faviconUrl = `${baseNoSlash}/favicon.svg`;
const appleTouchIconUrl = `${baseNoSlash}/apple-touch-icon.png`;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_GB';
const ogLocaleAlt = lang === 'fr' ? 'en_GB' : 'fr_FR';
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#b85a30" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="apple-touch-icon" href={appleTouchIconUrl} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="en-GB" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={frHref} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Terroir" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
  </head>
  <body>
    <header>
      <h1>{title}</h1>
      <nav>
        <a href={altHref} hreflang={htmlLang[altLang]} lang={htmlLang[altLang]}>
          {languages[altLang]}
        </a>
      </nav>
    </header>
    <slot />
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      body {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        overflow: hidden;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.25rem 0.75rem;
        border-bottom: 1px solid #e0e0e0;
        flex-shrink: 0;
      }
      header h1 {
        margin: 0;
        font-size: clamp(1rem, 4vw, 1.25rem);
      }
      header nav a {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: 0.5rem 0.75rem;
        color: inherit;
        text-decoration: none;
        font-size: 0.9375rem;
      }
      header nav a:hover,
      header nav a:focus-visible {
        text-decoration: underline;
      }
      header nav a:focus-visible {
        outline: 2px solid #005fcc;
        outline-offset: 2px;
        border-radius: 2px;
      }
    </style>
  </body>
</html>
