---
import { ui, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = ui[lang];
---

<button
  type="button"
  id="intro-toggle"
  class="intro-toggle"
  aria-label={t['intro.toggle']}
  aria-haspopup="dialog"
  aria-controls="intro-dialog"
>
  ?
</button>

<dialog id="intro-dialog" class="intro-dialog" aria-labelledby="intro-title">
  <form method="dialog" class="intro-content">
    <header class="intro-header">
      <h2 id="intro-title">{t['intro.title']}</h2>
      <button
        type="submit"
        class="intro-close"
        aria-label={t['intro.close']}
        value="close"
      >
        ×
      </button>
    </header>

    <p class="intro-lead">{t['intro.lead']}</p>

    <ul class="intro-legend">
      <li>
        <svg
          class="intro-marker intro-marker--pin"
          viewBox="0 0 24 36"
          aria-hidden="true"
        >
          <path
            d="M12 0 C5 0 0 5 0 12 C0 22 12 36 12 36 C12 36 24 22 24 12 C24 5 19 0 12 0 Z"
            fill="#2A81CB"></path>
          <circle cx="12" cy="12" r="4" fill="white"></circle>
        </svg>
        <div>
          <strong>{t['intro.aop.title']}</strong>
          <p>{t['intro.aop.description']}</p>
        </div>
      </li>
      <li>
        <svg
          class="intro-marker intro-marker--dot"
          viewBox="0 0 22 22"
          aria-hidden="true"
        >
          <circle
            cx="11"
            cy="11"
            r="9"
            fill="#b85a30"
            stroke="white"
            stroke-width="2"></circle>
        </svg>
        <div>
          <strong>{t['intro.dish.title']}</strong>
          <p>{t['intro.dish.description']}</p>
        </div>
      </li>
    </ul>

    <p class="intro-usage">{t['intro.usage']}</p>

    <button type="submit" class="intro-dismiss" value="dismiss">
      {t['intro.dismiss']}
    </button>
  </form>
</dialog>

<script>
  const STORAGE_KEY = 'terroir.intro.dismissed';

  const dialog = document.getElementById('intro-dialog') as HTMLDialogElement;
  const toggle = document.getElementById('intro-toggle') as HTMLButtonElement;

  function rememberDismissal(): void {
    try {
      localStorage.setItem(STORAGE_KEY, '1');
    } catch {
      // localStorage may be unavailable (private browsing, quota, etc.)
    }
  }

  function hasBeenDismissed(): boolean {
    try {
      return localStorage.getItem(STORAGE_KEY) === '1';
    } catch {
      return false;
    }
  }

  toggle.addEventListener('click', () => dialog.showModal());

  // Any close path (× button, dismiss button, ESC, backdrop click) remembers.
  dialog.addEventListener('close', rememberDismissal);

  // Backdrop click: clicks outside the form land on the dialog element itself.
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  if (!hasBeenDismissed()) dialog.showModal();
</script>

<style is:global>
  .intro-toggle {
    position: fixed;
    top: calc(env(safe-area-inset-top, 0px) + 4.5rem);
    right: 1.25rem;
    z-index: 1000;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--color-terracotta);
    font: inherit;
    font-size: 1.125rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    transition:
      transform 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease;
  }
  .intro-toggle:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
    box-shadow: var(--shadow-elevated);
  }
  .intro-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .intro-toggle {
      transition: none;
    }
  }

  .intro-dialog {
    border: 1px solid var(--glass-border);
    padding: 0;
    border-radius: 20px;
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--color-text);
    max-width: 28rem;
    width: calc(100% - 2rem);
    max-height: 90dvh;
    box-shadow: var(--shadow-elevated);
  }
  .intro-dialog::backdrop {
    background: rgba(20, 12, 8, 0.4);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .intro-content {
    margin: 0;
    padding: 1.5rem 1.75rem 1.75rem;
    max-height: 90dvh;
    overflow-y: auto;
  }

  .intro-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .intro-header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-terracotta);
  }
  .intro-close {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    border-radius: 999px;
    color: var(--color-text-muted);
    transition: background 0.15s ease;
  }
  .intro-close:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--color-text);
  }
  .intro-close:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .intro-lead {
    margin: 0 0 1.25rem;
    line-height: 1.55;
  }

  .intro-legend {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .intro-legend li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .intro-legend strong {
    display: block;
    margin-bottom: 0.125rem;
  }
  .intro-legend p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .intro-marker {
    flex-shrink: 0;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.18));
  }
  .intro-marker--pin {
    width: 26px;
    height: 38px;
    margin-top: 0.125rem;
  }
  .intro-marker--dot {
    width: 22px;
    height: 22px;
    margin-top: 0.375rem;
  }

  .intro-usage {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 1.25rem 0 1.5rem;
    line-height: 1.55;
  }

  .intro-dismiss {
    width: 100%;
    min-height: 48px;
    padding: 0.625rem 1.125rem;
    background: var(--color-terracotta);
    color: white;
    border: none;
    border-radius: 12px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 1px 2px rgba(160, 77, 40, 0.4);
    transition:
      background 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.15s ease;
  }
  .intro-dismiss:hover {
    background: var(--color-terracotta-hover);
    box-shadow:
      0 1px 2px rgba(160, 77, 40, 0.4),
      0 8px 20px rgba(160, 77, 40, 0.25);
    transform: translateY(-1px);
  }
  .intro-dismiss:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .intro-dismiss {
      transition: none;
    }
  }
</style>
