---
import 'leaflet/dist/leaflet.css';
import 'leaflet.markercluster/dist/MarkerCluster.css';
import 'leaflet.markercluster/dist/MarkerCluster.Default.css';
import { ui, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = ui[lang];
---

<main id="map" aria-label={t['map.label']}>
  <div class="map-loading" data-map-loading aria-hidden="true">
    <span class="map-loading__spinner"></span>
  </div>
</main>
<script>
  import L from 'leaflet';
  import 'leaflet.markercluster';
  import { getClientI18n } from '../lib/i18n-client';
  import { escapeHtml, normalize } from '../lib/text';
  import { haversineKm } from '../lib/distance';
  import { classifyAop } from '../lib/aop';
  import { PIN_PATH, PIN_VIEWBOX } from '../lib/markers';
  import { buildSlugMap } from '../lib/slug';
  import {
    PRODUCT_CATEGORIES,
    type AopRecord,
    type DishRecord,
    type FilterState,
    type FilterType,
    type LocateErrorCode,
    type NearbyItem,
    type ProductCategory,
  } from '../lib/types';

  interface Entry {
    id: string;
    marker: L.Marker;
    type: FilterType;
    category: ProductCategory | null;
    haystack: string;
    name: string;
    sub: string;
    lat: number;
    lng: number;
  }

  const { lang, t } = getClientI18n();

  const reducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  const FRANCE_BOUNDS: L.LatLngBoundsLiteral = [
    [40, -7],
    [52, 12],
  ];

  const map = L.map('map', {
    zoomAnimation: !reducedMotion,
    fadeAnimation: !reducedMotion,
    markerZoomAnimation: !reducedMotion,
    attributionControl: false,
    minZoom: 5,
    maxBounds: FRANCE_BOUNDS,
    maxBoundsViscosity: 0.8,
    worldCopyJump: false,
  }).setView([46.6, 2.5], 6);
  L.control.attribution({ position: 'bottomleft' }).addTo(map);

  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  }).addTo(map);

  const loadingEl = document.querySelector<HTMLElement>('[data-map-loading]');
  function hideLoading(): void {
    if (loadingEl) loadingEl.hidden = true;
  }

  function showError(message: string, retryLabel: string): void {
    hideLoading();
    const overlay = document.createElement('div');
    overlay.className = 'map-error';
    overlay.setAttribute('role', 'alert');
    overlay.innerHTML = `
      <p>${escapeHtml(message)}</p>
      <button type="button">${escapeHtml(retryLabel)}</button>
    `;
    overlay.querySelector('button')?.addEventListener('click', () => {
      location.reload();
    });
    document.getElementById('map')?.appendChild(overlay);
  }

  const aopIcon = L.divIcon({
    className: 'aop-marker',
    iconSize: [26, 38],
    iconAnchor: [13, 36],
    popupAnchor: [0, -34],
    html: `<svg viewBox="${PIN_VIEWBOX}" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="${PIN_PATH}" fill="#707a32" stroke="white" stroke-width="1.5"/><circle cx="13" cy="13" r="4.5" fill="white"/></svg>`,
  });

  const dishIcon = L.divIcon({
    className: 'dish-marker',
    iconSize: [22, 22],
    iconAnchor: [11, 11],
    popupAnchor: [0, -11],
    html: '<span class="dish-marker__dot" aria-hidden="true"></span>',
  });

  const userIcon = L.divIcon({
    className: 'user-marker',
    iconSize: [22, 22],
    iconAnchor: [11, 11],
    html: '<span class="user-marker__dot" aria-hidden="true"></span>',
  });

  const NEARBY_LIMIT = 15;
  const FETCH_TIMEOUT_MS = 15000;
  const ZOOM_TO_TARGET = 11;
  const FLY_THRESHOLD_M = 5000;

  async function fetchJson<T>(url: string): Promise<T> {
    const res = await fetch(url, {
      signal: AbortSignal.timeout(FETCH_TIMEOUT_MS),
    });
    if (!res.ok) throw new Error(`${url} HTTP ${res.status}`);
    return res.json() as Promise<T>;
  }

  try {
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    const [aops, dishes] = await Promise.all([
      fetchJson<AopRecord[]>(`${base}/data/aops.json`),
      fetchJson<DishRecord[]>(`${base}/data/dishes.json`),
    ]);

    const slugByIda = buildSlugMap(aops);
    const detailBase = lang === 'fr' ? `${base}/aops/` : `${base}/en/aops/`;

    const aopCluster = L.markerClusterGroup({
      chunkedLoading: true,
      maxClusterRadius: 50,
    });
    const dishCluster = L.markerClusterGroup({
      chunkedLoading: true,
      maxClusterRadius: 50,
    });
    map.addLayer(aopCluster);
    map.addLayer(dishCluster);

    const entries: Entry[] = [];

    for (const aop of aops) {
      const [lng, lat] = aop.centroid;
      const count = aop.products.length;
      const productLabel =
        count === 1 ? t['aop.product.one'] : t['aop.product.other'];
      const sign = aop.signeUE?.trim() ?? '';
      const singleProduct = count === 1 ? aop.products[0] : null;
      const productsBlock =
        count > 1
          ? `<details class="aop-popup__products">
              <summary><span class="aop-popup__count">${count} ${escapeHtml(productLabel)}</span></summary>
              <ul>${aop.products.map((p) => `<li>${escapeHtml(p)}</li>`).join('')}</ul>
            </details>`
          : singleProduct && singleProduct !== aop.name
            ? `<div class="aop-popup__single">${escapeHtml(singleProduct)}</div>`
            : '';
      const slug = slugByIda.get(aop.ida);
      const detailLink = slug
        ? `<a class="aop-popup__details" href="${detailBase}${slug}/">${escapeHtml(t['aop.popup.details'])}</a>`
        : '';
      const html = `
        <div class="aop-popup">
          <strong>${escapeHtml(aop.name)}</strong>
          ${sign ? `<div class="aop-popup__sign">${escapeHtml(sign)}</div>` : ''}
          ${productsBlock}
          ${detailLink}
        </div>
      `;
      const marker = L.marker([lat, lng], {
        icon: aopIcon,
        title: aop.name,
        alt: aop.name,
      }).bindPopup(html, { minWidth: 240, maxWidth: 280 });
      const aopType = classifyAop(aop.signeUE);
      entries.push({
        id: `${aopType}:${aop.ida}`,
        marker,
        type: aopType,
        category: aop.category,
        haystack: normalize([aop.name, ...aop.products, aop.region].join(' ')),
        name: aop.name,
        sub: sign,
        lat,
        lng,
      });
    }

    for (const dish of dishes) {
      const [lng, lat] = dish.centroid;
      const name = dish.name[lang];
      const description = dish.description[lang];
      const categoryLabel = t[`dish.category.${dish.category}`];
      const html = `
        <div class="dish-popup">
          <strong>${escapeHtml(name)}</strong>
          <div class="dish-popup__meta">${escapeHtml(categoryLabel)} · ${escapeHtml(dish.region)}</div>
          <p class="dish-popup__description">${escapeHtml(description)}</p>
        </div>
      `;
      const marker = L.marker([lat, lng], {
        icon: dishIcon,
        title: name,
        alt: name,
      }).bindPopup(html);
      entries.push({
        id: `dish:${dish.id}`,
        marker,
        type: 'dish',
        category: null,
        haystack: normalize(
          [dish.name.fr, dish.name.en, dish.region].join(' '),
        ),
        name,
        sub: `${categoryLabel} · ${dish.region}`,
        lat,
        lng,
      });
    }

    let currentFilterState: FilterState = {
      types: new Set<FilterType>(['aop', 'igp', 'dish']),
      categories: new Set<ProductCategory>(PRODUCT_CATEGORIES),
      search: '',
    };

    const visible = new Set<string>();

    function applyFilter(state: FilterState): void {
      currentFilterState = state;
      const aopAdd: L.Marker[] = [];
      const dishAdd: L.Marker[] = [];
      const aopRemove: L.Marker[] = [];
      const dishRemove: L.Marker[] = [];
      const byType: Record<FilterType, number> = { aop: 0, igp: 0, dish: 0 };
      const byCategory = Object.fromEntries(
        PRODUCT_CATEGORIES.map((c) => [c, 0]),
      ) as Record<ProductCategory, number>;
      const needle = normalize(state.search);
      let total = 0;
      for (const entry of entries) {
        const matches =
          state.types.has(entry.type) &&
          (!entry.category || state.categories.has(entry.category)) &&
          (!needle || entry.haystack.includes(needle));
        if (matches) {
          total++;
          byType[entry.type]++;
          if (entry.category) byCategory[entry.category]++;
        }
        const wasVisible = visible.has(entry.id);
        if (matches && !wasVisible) {
          visible.add(entry.id);
          if (entry.type === 'dish') dishAdd.push(entry.marker);
          else aopAdd.push(entry.marker);
        } else if (!matches && wasVisible) {
          visible.delete(entry.id);
          if (entry.type === 'dish') dishRemove.push(entry.marker);
          else aopRemove.push(entry.marker);
        }
      }
      if (aopRemove.length > 0) aopCluster.removeLayers(aopRemove);
      if (dishRemove.length > 0) dishCluster.removeLayers(dishRemove);
      if (aopAdd.length > 0) aopCluster.addLayers(aopAdd);
      if (dishAdd.length > 0) dishCluster.addLayers(dishAdd);

      window.dispatchEvent(
        new CustomEvent('filter:applied', {
          detail: { count: total, total: entries.length, byType, byCategory },
        }),
      );
    }

    applyFilter(currentFilterState);

    window.addEventListener('filter:change', (e: Event) => {
      applyFilter((e as CustomEvent<FilterState>).detail);
    });

    const focusIda = Number(new URLSearchParams(location.search).get('id'));
    if (Number.isFinite(focusIda) && focusIda > 0) {
      const target = entries.find(
        (e) => e.type !== 'dish' && e.id.endsWith(`:${focusIda}`),
      );
      if (target) {
        aopCluster.zoomToShowLayer(target.marker, () => {
          target.marker.openPopup();
        });
      }
    }

    let userMarker: L.Marker | null = null;
    let userCircle: L.Circle | null = null;
    let userLatLng: [number, number] | null = null;
    const entriesById = new Map(entries.map((e) => [e.id, e]));

    function computeNearby(): NearbyItem[] {
      if (!userLatLng) return [];
      const [uLat, uLng] = userLatLng;
      const needle = normalize(currentFilterState.search);
      const results: NearbyItem[] = [];
      for (const entry of entries) {
        if (!currentFilterState.types.has(entry.type)) continue;
        if (
          entry.category &&
          !currentFilterState.categories.has(entry.category)
        )
          continue;
        if (needle && !entry.haystack.includes(needle)) continue;
        results.push({
          id: entry.id,
          type: entry.type,
          name: entry.name,
          sub: entry.sub,
          distanceKm: haversineKm(uLat, uLng, entry.lat, entry.lng),
        });
      }
      results.sort((a, b) => a.distanceKm - b.distanceKm);
      return results.slice(0, NEARBY_LIMIT);
    }

    function emitNearby(): void {
      window.dispatchEvent(
        new CustomEvent('locate:result', {
          detail: { items: computeNearby() },
        }),
      );
    }

    window.addEventListener('locate:request', () => {
      if (!('geolocation' in navigator)) {
        window.dispatchEvent(
          new CustomEvent('locate:error', { detail: { code: 'unsupported' } }),
        );
        return;
      }
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          const lat = pos.coords.latitude;
          const lng = pos.coords.longitude;
          const accuracy = Math.max(20, pos.coords.accuracy);
          userLatLng = [lat, lng];

          if (userMarker) userMarker.remove();
          if (userCircle) userCircle.remove();

          userCircle = L.circle([lat, lng], {
            radius: accuracy,
            color: '#2a81cb',
            weight: 1,
            fillColor: '#2a81cb',
            fillOpacity: 0.12,
            interactive: false,
          }).addTo(map);
          userMarker = L.marker([lat, lng], {
            icon: userIcon,
            title: t['locate.you'],
            alt: t['locate.you'],
            interactive: false,
            keyboard: false,
            zIndexOffset: 1000,
          }).addTo(map);

          const targetZoom = Math.max(map.getZoom(), 9);
          map.flyTo([lat, lng], targetZoom, {
            animate: !reducedMotion,
            duration: reducedMotion ? 0 : 1.0,
          });
          emitNearby();
        },
        (err) => {
          let code: LocateErrorCode = 'unavailable';
          if (err.code === err.PERMISSION_DENIED) code = 'denied';
          else if (err.code === err.TIMEOUT) code = 'timeout';
          window.dispatchEvent(
            new CustomEvent('locate:error', { detail: { code } }),
          );
        },
        { enableHighAccuracy: false, timeout: 15000, maximumAge: 60000 },
      );
    });

    window.addEventListener('locate:clear', () => {
      userLatLng = null;
      if (userMarker) {
        userMarker.remove();
        userMarker = null;
      }
      if (userCircle) {
        userCircle.remove();
        userCircle = null;
      }
    });

    window.addEventListener('locate:focus', (e: Event) => {
      const id = (e as CustomEvent<{ id: string }>).detail.id;
      const entry = entriesById.get(id);
      if (!entry) return;
      const cluster = entry.type === 'dish' ? dishCluster : aopCluster;
      const reveal = (): void => {
        cluster.zoomToShowLayer(entry.marker, () => {
          entry.marker.openPopup();
        });
      };
      const currentZoom = map.getZoom();
      const targetZoom = Math.max(currentZoom, ZOOM_TO_TARGET);
      const distanceMeters = map.distance(map.getCenter(), [
        entry.lat,
        entry.lng,
      ]);
      if (distanceMeters > FLY_THRESHOLD_M || currentZoom < targetZoom) {
        map.once('moveend', reveal);
        map.flyTo([entry.lat, entry.lng], targetZoom, {
          animate: !reducedMotion,
          duration: reducedMotion ? 0 : 0.8,
        });
      } else {
        reveal();
      }
    });

    window.addEventListener('locate:recompute', emitNearby);

    hideLoading();
  } catch (err) {
    console.error('Failed to load map data', err);
    showError(t['error.dataLoad'], t['error.retry']);
  }
</script>
<style is:global>
  #map {
    flex: 1;
    min-height: 0;
    width: 100%;
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-elevated);
    background: #cfe1f0;
  }

  .leaflet-top {
    top: 0.875rem;
  }
  .leaflet-bottom {
    bottom: 0.875rem;
  }
  .leaflet-left {
    left: 0.875rem;
  }
  .leaflet-right {
    right: 0.875rem;
  }
  .leaflet-top.leaflet-left {
    top: 4.25rem;
  }
  .leaflet-bottom.leaflet-left {
    left: 50%;
    right: auto;
    transform: translateX(-50%);
  }

  .leaflet-control-zoom {
    border: 1px solid var(--glass-border) !important;
    border-radius: 12px !important;
    overflow: hidden;
    box-shadow: var(--shadow-soft) !important;
  }
  .leaflet-control-zoom a {
    background: var(--glass-bg) !important;
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--color-text) !important;
    border-bottom-color: var(--glass-border) !important;
  }
  .leaflet-control-zoom a:hover {
    background: rgba(255, 255, 255, 0.92) !important;
  }
  .leaflet-control-attribution {
    background: rgba(255, 255, 255, 0.75) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 6px;
    padding: 0 0.5rem !important;
  }
  .aop-popup__sign {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }
  .aop-popup__count {
    margin-top: 0.25rem;
    font-size: 0.875rem;
  }
  .aop-popup__products {
    margin-top: 0.25rem;
  }
  .aop-popup__products > summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.25rem;
    margin: -0.125rem -0.25rem;
    border-radius: 4px;
    color: var(--color-text);
  }
  .aop-popup__products > summary::-webkit-details-marker {
    display: none;
  }
  .aop-popup__products > summary::before {
    content: '';
    width: 0;
    height: 0;
    border-left: 4px solid var(--color-text-muted);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    transition: transform 0.15s ease;
  }
  .aop-popup__products[open] > summary::before {
    transform: rotate(90deg);
  }
  .aop-popup__products > summary:hover {
    background: rgba(112, 122, 50, 0.08);
  }
  .aop-popup__products > summary:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
  }
  .aop-popup__products .aop-popup__count {
    margin: 0;
  }
  .aop-popup__products ul {
    margin: 0.5rem 0 0;
    padding: 0.5rem 0 0;
    list-style: none;
    max-height: 14rem;
    overflow-y: auto;
    border-top: 1px solid var(--glass-border);
  }
  .aop-popup__products li {
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.125rem 0;
    color: var(--color-text);
  }
  .aop-popup__single {
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text);
  }
  .aop-popup__details {
    display: inline-flex;
    align-items: center;
    margin-top: 0.5rem;
    padding: 0.25rem 0.5rem;
    margin-left: -0.5rem;
    color: var(--color-terracotta);
    font-weight: 600;
    font-size: 0.8125rem;
    text-decoration: none;
    border-radius: 4px;
  }
  .aop-popup__details:hover {
    color: var(--color-terracotta-hover);
    text-decoration: underline;
  }
  .aop-popup__details:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
  }
  @media (prefers-reduced-motion: reduce) {
    .aop-popup__products > summary::before {
      transition: none;
    }
  }

  .aop-marker {
    background: transparent;
    border: none;
  }
  .aop-marker svg {
    display: block;
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.28));
    transition: transform 0.15s ease;
    transform-origin: 50% 100%;
  }
  .aop-marker:hover svg {
    transform: scale(1.18);
  }

  .dish-marker {
    background: transparent;
    border: none;
  }
  .dish-marker__dot {
    display: block;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-terracotta);
    border: 2px solid white;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
    transition: transform 0.15s ease;
  }
  .dish-marker:hover .dish-marker__dot {
    transform: scale(1.18);
  }

  .marker-cluster {
    transition: transform 0.15s ease;
  }
  .marker-cluster:hover {
    transform: scale(1.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .aop-marker svg,
    .dish-marker__dot,
    .marker-cluster {
      transition: none;
    }
  }

  .marker-cluster {
    background-clip: padding-box;
  }
  .marker-cluster div {
    width: 32px;
    height: 32px;
    margin-left: 4px;
    margin-top: 4px;
    border-radius: 50%;
    color: white;
    font: inherit;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
  }
  .marker-cluster span {
    line-height: 32px;
  }
  .marker-cluster-small {
    background: rgba(112, 122, 50, 0.28);
  }
  .marker-cluster-small div {
    background: rgba(112, 122, 50, 0.95);
  }
  .marker-cluster-medium {
    background: rgba(192, 121, 60, 0.3);
  }
  .marker-cluster-medium div {
    background: rgba(192, 121, 60, 0.95);
  }
  .marker-cluster-large {
    background: rgba(160, 77, 40, 0.32);
  }
  .marker-cluster-large div {
    background: rgba(160, 77, 40, 0.97);
  }
  .dish-popup__meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }
  .dish-popup__description {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.4;
    max-width: 260px;
  }

  .leaflet-popup-content-wrapper {
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    box-shadow: var(--shadow-elevated);
    padding: 0;
  }
  .leaflet-popup-content {
    margin: 0.875rem 1rem;
    font-family: var(--font-body);
    line-height: 1.4;
  }
  .leaflet-popup-tip {
    background: rgba(255, 255, 255, 0.78);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: none;
  }
  .leaflet-popup-close-button {
    color: var(--color-text-muted) !important;
    padding: 6px 8px !important;
  }
  .leaflet-popup-close-button:hover {
    color: var(--color-text) !important;
  }
  .aop-popup strong,
  .dish-popup strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
  }

  .leaflet-marker-icon:focus-visible,
  .leaflet-marker-icon:focus,
  .leaflet-interactive:focus-visible,
  .leaflet-control-zoom a:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (pointer: coarse) {
    .leaflet-touch .leaflet-bar a {
      width: 44px;
      height: 44px;
      line-height: 44px;
      font-size: 22px;
    }
  }

  .map-loading {
    position: absolute;
    inset: 0;
    z-index: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background: rgba(207, 225, 240, 0.6);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
  }
  .map-loading[hidden] {
    display: none;
  }
  .map-loading__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(184, 90, 48, 0.25);
    border-top-color: var(--color-terracotta);
    border-radius: 50%;
    animation: map-loading-spin 0.8s linear infinite;
  }
  @keyframes map-loading-spin {
    to {
      transform: rotate(360deg);
