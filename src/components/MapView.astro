<div id="map"></div>
<script>
  import L from 'leaflet';

  const map = L.map('map').setView([46.6, 2.5], 6);
  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  }).addTo(map);
</script>
<style is:global>
  #map {
    flex: 1;
    min-height: 0;
    width: 100%;
  }
</style>
