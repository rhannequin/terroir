---
import 'leaflet/dist/leaflet.css';
import 'leaflet.markercluster/dist/MarkerCluster.css';
import 'leaflet.markercluster/dist/MarkerCluster.Default.css';
import { ui, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = ui[lang];
---

<main id="map" aria-label={t['map.label']}></main>
<script>
  import L from 'leaflet';
  import 'leaflet.markercluster';
  import { ui, type Lang } from '../i18n/ui';

  type FilterType = 'aop' | 'igp' | 'dish';

  interface Aop {
    ida: number;
    name: string;
    signeUE: string | null;
    signeFR: string | null;
    products: string[];
    communeCount: number;
    centroid: [number, number];
  }

  interface Dish {
    id: string;
    name: { fr: string; en: string };
    description: { fr: string; en: string };
    category:
      | 'main'
      | 'soup'
      | 'starter'
      | 'side'
      | 'charcuterie'
      | 'cheese-dish'
      | 'pastry'
      | 'dessert'
      | 'snack';
    region: string;
    locationType: 'commune' | 'department' | 'region' | 'area';
    centroid: [number, number];
  }

  interface Entry {
    marker: L.Marker;
    type: FilterType;
    haystack: string;
  }

  interface FilterState {
    types: Set<FilterType>;
    search: string;
  }

  const lang: Lang = document.documentElement.lang.startsWith('fr')
    ? 'fr'
    : 'en';
  const t = ui[lang];

  const reducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  const map = L.map('map', {
    zoomAnimation: !reducedMotion,
    fadeAnimation: !reducedMotion,
    markerZoomAnimation: !reducedMotion,
    attributionControl: false,
  }).setView([46.6, 2.5], 6);
  L.control.attribution({ position: 'bottomleft' }).addTo(map);

  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  }).addTo(map);

  const escapeHtml = (s: string) =>
    s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');

  const normalize = (s: string) =>
    s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

  function showError(message: string, retryLabel: string): void {
    const overlay = document.createElement('div');
    overlay.className = 'map-error';
    overlay.setAttribute('role', 'alert');
    overlay.innerHTML = `
      <p>${escapeHtml(message)}</p>
      <button type="button">${escapeHtml(retryLabel)}</button>
    `;
    overlay.querySelector('button')?.addEventListener('click', () => {
      location.reload();
    });
    document.getElementById('map')?.appendChild(overlay);
  }

  const aopIcon = L.divIcon({
    className: 'aop-marker',
    iconSize: [26, 38],
    iconAnchor: [13, 36],
    popupAnchor: [0, -34],
    html: `<svg viewBox="0 0 26 38" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M13 1 C7 1 1 6 1 13 C1 23 13 37 13 37 C13 37 25 23 25 13 C25 6 19 1 13 1 Z" fill="#707a32" stroke="white" stroke-width="1.5"/><circle cx="13" cy="13" r="4.5" fill="white"/></svg>`,
  });

  const dishIcon = L.divIcon({
    className: 'dish-marker',
    iconSize: [22, 22],
    iconAnchor: [11, 11],
    popupAnchor: [0, -11],
    html: '<span class="dish-marker__dot" aria-hidden="true"></span>',
  });

  function classifyAop(signe: string | null): FilterType {
    const s = signe?.trim().toLowerCase() ?? '';
    if (s === 'igp' || s === 'ig') return 'igp';
    return 'aop';
  }

  try {
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    const [aopsRes, dishesRes] = await Promise.all([
      fetch(`${base}/data/aops.json`),
      fetch(`${base}/data/dishes.json`),
    ]);
    if (!aopsRes.ok) throw new Error(`aops.json HTTP ${aopsRes.status}`);
    if (!dishesRes.ok) throw new Error(`dishes.json HTTP ${dishesRes.status}`);
    const [aops, dishes]: [Aop[], Dish[]] = await Promise.all([
      aopsRes.json(),
      dishesRes.json(),
    ]);

    const aopCluster = L.markerClusterGroup({
      chunkedLoading: true,
      maxClusterRadius: 50,
    });
    const dishCluster = L.markerClusterGroup({
      chunkedLoading: true,
      maxClusterRadius: 50,
    });
    map.addLayer(aopCluster);
    map.addLayer(dishCluster);

    const entries: Entry[] = [];

    for (const aop of aops) {
      const [lng, lat] = aop.centroid;
      const count = aop.products.length;
      const productLabel =
        count === 1 ? t['aop.product.one'] : t['aop.product.other'];
      const sign = aop.signeUE?.trim() ?? '';
      const productsBlock =
        count > 1
          ? `<details class="aop-popup__products">
              <summary><span class="aop-popup__count">${count} ${escapeHtml(productLabel)}</span></summary>
              <ul>${aop.products.map((p) => `<li>${escapeHtml(p)}</li>`).join('')}</ul>
            </details>`
          : `<div class="aop-popup__count">${count} ${escapeHtml(productLabel)}</div>`;
      const html = `
        <div class="aop-popup">
          <strong>${escapeHtml(aop.name)}</strong>
          ${sign ? `<div class="aop-popup__sign">${escapeHtml(sign)}</div>` : ''}
          ${productsBlock}
        </div>
      `;
      const marker = L.marker([lat, lng], {
        icon: aopIcon,
        title: aop.name,
        alt: aop.name,
      }).bindPopup(html, { minWidth: 240, maxWidth: 280 });
      entries.push({
        marker,
        type: classifyAop(aop.signeUE),
        haystack: normalize([aop.name, ...aop.products].join(' ')),
      });
    }

    for (const dish of dishes) {
      const [lng, lat] = dish.centroid;
      const name = dish.name[lang];
      const description = dish.description[lang];
      const categoryLabel = t[`dish.category.${dish.category}`];
      const html = `
        <div class="dish-popup">
          <strong>${escapeHtml(name)}</strong>
          <div class="dish-popup__meta">${escapeHtml(categoryLabel)} · ${escapeHtml(dish.region)}</div>
          <p class="dish-popup__description">${escapeHtml(description)}</p>
        </div>
      `;
      const marker = L.marker([lat, lng], {
        icon: dishIcon,
        title: name,
        alt: name,
      }).bindPopup(html);
      entries.push({
        marker,
        type: 'dish',
        haystack: normalize(
          [dish.name.fr, dish.name.en, dish.region].join(' '),
        ),
      });
    }

    function applyFilter(state: FilterState): void {
      const aopMatches: L.Marker[] = [];
      const dishMatches: L.Marker[] = [];
      const byType: Record<FilterType, number> = {
        aop: 0,
        igp: 0,
        dish: 0,
      };
      const needle = normalize(state.search);
      for (const entry of entries) {
        if (!state.types.has(entry.type)) continue;
        if (needle && !entry.haystack.includes(needle)) continue;
        byType[entry.type]++;
        if (entry.type === 'dish') dishMatches.push(entry.marker);
        else aopMatches.push(entry.marker);
      }
      aopCluster.clearLayers();
      dishCluster.clearLayers();
      aopCluster.addLayers(aopMatches);
      dishCluster.addLayers(dishMatches);

      window.dispatchEvent(
        new CustomEvent('filter:applied', {
          detail: {
            count: aopMatches.length + dishMatches.length,
            total: entries.length,
            byType,
          },
        }),
      );
    }

    applyFilter({
      types: new Set<FilterType>(['aop', 'igp', 'dish']),
      search: '',
    });

    window.addEventListener('filter:change', (e: Event) => {
      applyFilter((e as CustomEvent<FilterState>).detail);
    });
  } catch (err) {
    console.error('Failed to load map data', err);
    showError(t['error.dataLoad'], t['error.retry']);
  }
</script>
<style is:global>
  #map {
    flex: 1;
    min-height: 0;
    width: 100%;
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-elevated);
    background: #cfe1f0;
  }

  .leaflet-top {
    top: 0.875rem;
  }
  .leaflet-bottom {
    bottom: 0.875rem;
  }
  .leaflet-left {
    left: 0.875rem;
  }
  .leaflet-right {
    right: 0.875rem;
  }
  .leaflet-top.leaflet-left {
    top: 4.25rem;
  }

  .leaflet-control-zoom {
    border: 1px solid var(--glass-border) !important;
    border-radius: 12px !important;
    overflow: hidden;
    box-shadow: var(--shadow-soft) !important;
  }
  .leaflet-control-zoom a {
    background: var(--glass-bg) !important;
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--color-text) !important;
    border-bottom-color: var(--glass-border) !important;
  }
  .leaflet-control-zoom a:hover {
    background: rgba(255, 255, 255, 0.92) !important;
  }
  .leaflet-control-attribution {
    background: rgba(255, 255, 255, 0.75) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 6px;
    padding: 0 0.5rem !important;
  }
  .aop-popup__sign {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }
  .aop-popup__count {
    margin-top: 0.25rem;
    font-size: 0.875rem;
  }
  .aop-popup__products {
    margin-top: 0.25rem;
  }
  .aop-popup__products > summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.25rem;
    margin: -0.125rem -0.25rem;
    border-radius: 4px;
    color: var(--color-text);
  }
  .aop-popup__products > summary::-webkit-details-marker {
    display: none;
  }
  .aop-popup__products > summary::before {
    content: '';
    width: 0;
    height: 0;
    border-left: 4px solid var(--color-text-muted);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    transition: transform 0.15s ease;
  }
  .aop-popup__products[open] > summary::before {
    transform: rotate(90deg);
  }
  .aop-popup__products > summary:hover {
    background: rgba(112, 122, 50, 0.08);
  }
  .aop-popup__products > summary:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
  }
  .aop-popup__products .aop-popup__count {
    margin: 0;
  }
  .aop-popup__products ul {
    margin: 0.5rem 0 0;
    padding: 0.5rem 0 0;
    list-style: none;
    max-height: 14rem;
    overflow-y: auto;
    border-top: 1px solid var(--glass-border);
  }
  .aop-popup__products li {
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.125rem 0;
    color: var(--color-text);
  }
  @media (prefers-reduced-motion: reduce) {
    .aop-popup__products > summary::before {
      transition: none;
    }
  }

  .aop-marker {
    background: transparent;
    border: none;
  }
  .aop-marker svg {
    display: block;
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.28));
    transition: transform 0.15s ease;
    transform-origin: 50% 100%;
  }
  .aop-marker:hover svg {
    transform: scale(1.18);
  }

  .dish-marker {
    background: transparent;
    border: none;
  }
  .dish-marker__dot {
    display: block;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-terracotta);
    border: 2px solid white;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
    transition: transform 0.15s ease;
  }
  .dish-marker:hover .dish-marker__dot {
    transform: scale(1.18);
  }

  .marker-cluster {
    transition: transform 0.15s ease;
  }
  .marker-cluster:hover {
    transform: scale(1.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .aop-marker svg,
    .dish-marker__dot,
    .marker-cluster {
      transition: none;
    }
  }

  .marker-cluster {
    background-clip: padding-box;
  }
  .marker-cluster div {
    width: 32px;
    height: 32px;
    margin-left: 4px;
    margin-top: 4px;
    border-radius: 50%;
    color: white;
    font: inherit;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
  }
  .marker-cluster span {
    line-height: 32px;
  }
  .marker-cluster-small {
    background: rgba(112, 122, 50, 0.28);
  }
  .marker-cluster-small div {
    background: rgba(112, 122, 50, 0.95);
  }
  .marker-cluster-medium {
    background: rgba(192, 121, 60, 0.3);
  }
  .marker-cluster-medium div {
    background: rgba(192, 121, 60, 0.95);
  }
  .marker-cluster-large {
    background: rgba(160, 77, 40, 0.32);
  }
  .marker-cluster-large div {
    background: rgba(160, 77, 40, 0.97);
  }
  .dish-popup__meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }
  .dish-popup__description {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.4;
    max-width: 260px;
  }

  .leaflet-popup-content-wrapper {
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    box-shadow: var(--shadow-elevated);
    padding: 0;
  }
  .leaflet-popup-content {
    margin: 0.875rem 1rem;
    font-family: var(--font-body);
    line-height: 1.4;
  }
  .leaflet-popup-tip {
    background: rgba(255, 255, 255, 0.78);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: none;
  }
  .leaflet-popup-close-button {
    color: var(--color-text-muted) !important;
    padding: 6px 8px !important;
  }
  .leaflet-popup-close-button:hover {
    color: var(--color-text) !important;
  }
  .aop-popup strong,
  .dish-popup strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
  }

  .leaflet-marker-icon:focus-visible,
  .leaflet-marker-icon:focus,
  .leaflet-interactive:focus-visible,
  .leaflet-control-zoom a:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (pointer: coarse) {
    .leaflet-touch .leaflet-bar a {
      width: 44px;
      height: 44px;
      line-height: 44px;
      font-size: 22px;
    }
  }

  .map-error {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 9999;
    background: white;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    max-width: min(90vw, 24rem);
    text-align: center;
  }
  .map-error p {
    margin: 0 0 0.75rem;
  }
  .map-error button {
    min-height: 44px;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-terracotta);
    background: var(--color-terracotta);
    color: white;
    border-radius: 6px;
    font: inherit;
    cursor: pointer;
  }
  .map-error button:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .leaflet-fade-anim .leaflet-tile,
    .leaflet-zoom-anim .leaflet-zoom-animated {
      transition: none !important;
    }
  }
</style>
