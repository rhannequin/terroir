---
import { ui, type Lang } from '../i18n/ui';
import { PIN_PATH, PIN_VIEWBOX, DOT_VIEWBOX } from '../lib/markers';
import { PRODUCT_CATEGORIES } from '../lib/types';

const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = ui[lang];
---

<button
  type="button"
  id="filter-toggle"
  class="filter-toggle"
  aria-expanded="false"
  aria-controls="filter-panel"
>
  <svg
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <line x1="4" y1="6" x2="20" y2="6"></line>
    <line x1="7" y1="12" x2="17" y2="12"></line>
    <line x1="10" y1="18" x2="14" y2="18"></line>
  </svg>
  <span class="filter-toggle__label">{t['filter.toggle']}</span>
  <span class="filter-toggle__count" hidden></span>
</button>

<section
  id="filter-panel"
  class="filter-panel"
  aria-labelledby="filter-panel-title"
  inert
>
  <header class="filter-panel__header">
    <h2 id="filter-panel-title">{t['filter.title']}</h2>
    <button
      type="button"
      class="filter-panel__close"
      aria-label={t['filter.close']}
      data-filter-close
    >
      ×
    </button>
  </header>

  <fieldset class="filter-panel__group">
    <legend>
      <span>{t['filter.type.legend']}</span>
      <button
        type="button"
        class="filter-panel__group-clear"
        data-clear-group="type"
        aria-label={t['filter.group.clear.aria']}
      >
        {t['filter.group.clear']}
      </button>
    </legend>
    <label class="filter-checkbox">
      <input type="checkbox" data-type="aop" checked />
      <svg
        class="filter-marker filter-marker--pin"
        viewBox={PIN_VIEWBOX}
        aria-hidden="true"
      >
        <path d={PIN_PATH} fill="#707a32" stroke="white" stroke-width="1.5"
        ></path>
        <circle cx="13" cy="13" r="4.5" fill="white"></circle>
      </svg>
      <span class="filter-checkbox__name">{t['filter.type.aop']}</span>
      <span class="filter-checkbox__count" data-count-for="aop"></span>
    </label>
    <label class="filter-checkbox">
      <input type="checkbox" data-type="igp" checked />
      <svg
        class="filter-marker filter-marker--pin"
        viewBox={PIN_VIEWBOX}
        aria-hidden="true"
      >
        <path d={PIN_PATH} fill="#707a32" stroke="white" stroke-width="1.5"
        ></path>
        <circle cx="13" cy="13" r="4.5" fill="white"></circle>
      </svg>
      <span class="filter-checkbox__name">{t['filter.type.igp']}</span>
      <span class="filter-checkbox__count" data-count-for="igp"></span>
    </label>
    <label class="filter-checkbox">
      <input type="checkbox" data-type="dish" checked />
      <svg
        class="filter-marker filter-marker--dot"
        viewBox={DOT_VIEWBOX}
        aria-hidden="true"
      >
        <circle
          cx="11"
          cy="11"
          r="9"
          fill="#b85a30"
          stroke="white"
          stroke-width="2"></circle>
      </svg>
      <span class="filter-checkbox__name">{t['filter.type.dish']}</span>
      <span class="filter-checkbox__count" data-count-for="dish"></span>
    </label>
  </fieldset>

  <fieldset class="filter-panel__group">
    <legend>
      <span>{t['filter.category.legend']}</span>
      <button
        type="button"
        class="filter-panel__group-clear"
        data-clear-group="category"
        aria-label={t['filter.group.clear.aria']}
      >
        {t['filter.group.clear']}
      </button>
    </legend>
    {
      PRODUCT_CATEGORIES.map((cat) => (
        <label class="filter-checkbox filter-checkbox--plain">
          <input type="checkbox" data-category={cat} checked />
          <span class="filter-checkbox__name">
            {t[`filter.category.${cat}`]}
          </span>
          <span class="filter-checkbox__count" data-cat-count={cat} />
        </label>
      ))
    }
  </fieldset>

  <label class="filter-panel__search">
    <span>{t['filter.search.label']}</span>
    <input
      type="search"
      id="filter-search"
      autocomplete="off"
      placeholder={t['filter.search.placeholder']}
    />
  </label>

  <div class="filter-panel__footer">
    <span id="filter-results" aria-live="polite"></span>
    <button type="button" id="filter-reset">{t['filter.reset']}</button>
  </div>
</section>

<script>
  import { getClientI18n, pluralKey } from '../lib/i18n-client';
  import { trapFocus } from '../lib/focus-trap';
  import {
    PRODUCT_CATEGORIES,
    type FilterApplied,
    type FilterState,
    type FilterType,
    type ProductCategory,
  } from '../lib/types';

  const { t, numberFmt, pluralRules } = getClientI18n();

  const toggle = document.getElementById('filter-toggle') as HTMLButtonElement;
  const panel = document.getElementById('filter-panel') as HTMLElement;
  const closeBtn = panel.querySelector<HTMLButtonElement>(
    '[data-filter-close]',
  )!;
  const resetBtn = document.getElementById('filter-reset') as HTMLButtonElement;
  const searchInput = document.getElementById(
    'filter-search',
  ) as HTMLInputElement;
  const typeBoxes =
    panel.querySelectorAll<HTMLInputElement>('input[data-type]');
  const categoryBoxes = panel.querySelectorAll<HTMLInputElement>(
    'input[data-category]',
  );
  const groupClearBtns =
    panel.querySelectorAll<HTMLButtonElement>('[data-clear-group]');
  const resultsEl = document.getElementById('filter-results') as HTMLElement;
  const countBadge = toggle.querySelector(
    '.filter-toggle__count',
  ) as HTMLElement;
  const typeCountEls = panel.querySelectorAll<HTMLElement>('[data-count-for]');
  const categoryCountEls =
    panel.querySelectorAll<HTMLElement>('[data-cat-count]');

  const ALL_TYPES: FilterType[] = ['aop', 'igp', 'dish'];

  function readState(): FilterState {
    const types = new Set<FilterType>();
    for (const cb of typeBoxes) {
      if (cb.checked) types.add(cb.dataset.type as FilterType);
    }
    const categories = new Set<ProductCategory>();
    for (const cb of categoryBoxes) {
      if (cb.checked) categories.add(cb.dataset.category as ProductCategory);
    }
    return { types, categories, search: searchInput.value.trim() };
  }

  function isFiltering(state: FilterState): boolean {
    return (
      state.types.size < ALL_TYPES.length ||
      state.categories.size < PRODUCT_CATEGORIES.length ||
      state.search.length > 0
    );
  }

  function emitChange(): void {
    const state = readState();
    window.dispatchEvent(
      new CustomEvent<FilterState>('filter:change', { detail: state }),
    );
    syncGroupClearState();
  }

  function syncGroupClearState(): void {
    for (const btn of groupClearBtns) {
      const boxes =
        btn.dataset.clearGroup === 'type' ? typeBoxes : categoryBoxes;
      btn.disabled = ![...boxes].some((cb) => cb.checked);
    }
  }

  function openPanel(): void {
    panel.classList.add('is-open');
    panel.removeAttribute('inert');
    toggle.setAttribute('aria-expanded', 'true');
    closeBtn.focus();
    window.dispatchEvent(new CustomEvent('filter:panel-opened'));
  }

  function closePanel(): void {
    panel.classList.remove('is-open');
    panel.setAttribute('inert', '');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.focus();
  }

  toggle.addEventListener('click', () => {
    if (panel.classList.contains('is-open')) closePanel();
    else openPanel();
  });
  closeBtn.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (!panel.classList.contains('is-open')) return;
    if (e.key === 'Escape') {
      closePanel();
      return;
    }
    trapFocus(panel, e);
  });

  let searchDebounce: ReturnType<typeof setTimeout> | undefined;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(emitChange, 150);
  });
  for (const cb of typeBoxes) cb.addEventListener('change', emitChange);
  for (const cb of categoryBoxes) cb.addEventListener('change', emitChange);
  resetBtn.addEventListener('click', () => {
    searchInput.value = '';
    for (const cb of typeBoxes) cb.checked = true;
    for (const cb of categoryBoxes) cb.checked = true;
    emitChange();
  });
  for (const btn of groupClearBtns) {
    btn.addEventListener('click', () => {
      const boxes =
        btn.dataset.clearGroup === 'type' ? typeBoxes : categoryBoxes;
      for (const cb of boxes) cb.checked = false;
      emitChange();
    });
  }
  syncGroupClearState();

  window.addEventListener('locate:panel-opened', () => {
    if (panel.classList.contains('is-open')) closePanel();
  });

  window.addEventListener('filter:applied', (e: Event) => {
    const { count, total, byType, byCategory } = (
      e as CustomEvent<FilterApplied>
    ).detail;
    const tmpl = t[`filter.results.${pluralKey(pluralRules, count)}`];
    resultsEl.textContent = tmpl.replace('{count}', numberFmt.format(count));

    for (const el of typeCountEls) {
      const type = el.dataset.countFor as FilterType;
      const n = byType[type] ?? 0;
      el.textContent = numberFmt.format(n);
      el.closest('.filter-checkbox')?.classList.toggle('is-empty', n === 0);
    }
    for (const el of categoryCountEls) {
      const cat = el.dataset.catCount as ProductCategory;
      const n = byCategory[cat] ?? 0;
      el.textContent = numberFmt.format(n);
      el.closest('.filter-checkbox')?.classList.toggle('is-empty', n === 0);
    }

    const state = readState();
    if (isFiltering(state) && count !== total) {
      countBadge.textContent = numberFmt.format(count);
      countBadge.hidden = false;
    } else {
      countBadge.hidden = true;
      countBadge.textContent = '';
    }
  });
</script>

<style is:global>
  .filter-toggle {
    position: fixed;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 1.25rem);
    right: calc(env(safe-area-inset-right, 0px) + 1.25rem);
    z-index: 999;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.625rem 1.125rem;
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--color-text);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    box-shadow: var(--shadow-elevated);
    font: inherit;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      background 0.15s ease;
  }
  .filter-toggle:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.85);
  }
  .filter-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }
  .filter-toggle__count {
    background: var(--color-terracotta);
    color: white;
    border-radius: 999px;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.25;
    min-width: 1.5rem;
    text-align: center;
  }
  .filter-toggle__count[hidden] {
    display: none;
  }

  .filter-panel {
    position: fixed;
    z-index: 1001;
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-elevated);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    overscroll-behavior: contain;
  }

  @media (max-width: 1023px) {
    .filter-toggle {
      bottom: calc(env(safe-area-inset-bottom, 0px) + 2.75rem);
    }
    .filter-panel {
      left: 0.5rem;
      right: 0.5rem;
      bottom: 0.5rem;
      max-height: 80dvh;
      overflow-y: auto;
      border-radius: 24px;
      transform: translateY(calc(100% + 1rem));
    }
    .filter-panel.is-open {
      transform: translateY(0);
    }
  }

  @media (min-width: 1024px) {
    .filter-panel {
      top: 4.75rem;
      right: 0.75rem;
      bottom: 0.75rem;
      width: 19rem;
      max-width: 90vw;
      overflow-y: auto;
      border-radius: 20px;
      transform: translateX(calc(100% + 1.5rem));
    }
    .filter-panel.is-open {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .filter-panel,
    .filter-toggle {
      transition: none;
    }
  }

  .filter-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .filter-panel__header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--color-terracotta);
  }
  .filter-panel__close {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    border-radius: 999px;
    color: var(--color-text-muted);
    transition: background 0.15s ease;
  }
  .filter-panel__close:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--color-text);
  }
  .filter-panel__close:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .filter-panel__group {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .filter-panel__group legend {
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    padding: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .filter-panel__group-clear {
    border: none;
    background: transparent;
    font: inherit;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-terracotta);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    margin: -0.25rem -0.5rem;
    border-radius: 6px;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      opacity 0.15s ease;
  }
  .filter-panel__group-clear:hover:not(:disabled) {
    background: rgba(184, 90, 48, 0.08);
  }
  .filter-panel__group-clear:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
  .filter-panel__group-clear:disabled {
    opacity: 0.4;
    cursor: default;
  }
  .filter-checkbox {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 0.625rem;
    min-height: 44px;
    cursor: pointer;
    font-size: 0.9375rem;
    user-select: none;
  }
  .filter-checkbox--plain {
    grid-template-columns: auto 1fr auto;
    min-height: 36px;
  }
  .filter-checkbox.is-empty .filter-checkbox__name,
  .filter-checkbox.is-empty .filter-checkbox__count {
    color: #b8b0a0;
  }
  .filter-checkbox.is-empty .filter-marker {
    opacity: 0.5;
  }
  .filter-checkbox__name {
    font-weight: 500;
  }
  .filter-checkbox__count {
    font-variant-numeric: tabular-nums;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .filter-marker {
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.18));
  }
  .filter-marker--pin {
    width: 18px;
    height: 26px;
  }
  .filter-marker--dot {
    width: 18px;
    height: 18px;
  }
  .filter-panel__group input[type='checkbox'] {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border: 1.5px solid #b8b0a0;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    display: inline-grid;
    place-content: center;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
    flex-shrink: 0;
  }
  .filter-panel__group input[type='checkbox']::before {
    content: '';
    width: 12px;
    height: 12px;
    transform: scale(0);
    transition: transform 0.15s ease;
    box-shadow: inset 1em 1em white;
    clip-path: polygon(14% 44%, 0 65%, 40% 100%, 100% 16%, 80% 0, 40% 60%);
  }
  .filter-panel__group input[type='checkbox']:checked {
    background: var(--color-terracotta);
    border-color: var(--color-terracotta);
  }
  .filter-panel__group input[type='checkbox']:checked::before {
    transform: scale(1);
  }
  .filter-panel__group input[type='checkbox']:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .filter-panel__search {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .filter-panel__search span {
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .filter-panel__search input {
    min-height: 44px;
    padding: 0.5rem 0.875rem;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: rgba(255, 255, 255, 0.7);
    border-radius: 12px;
    font: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      background 0.15s ease;
  }
  .filter-panel__search input::placeholder {
    color: #9b9385;
  }
  .filter-panel__search input:focus {
    outline: none;
    border-color: var(--color-terracotta);
    background: white;
    box-shadow: 0 0 0 3px rgba(184, 90, 48, 0.18);
  }
  .filter-panel__search input:focus-visible {
    outline: none;
  }
  @media (forced-colors: active) {
    .filter-panel__search input:focus,
    .filter-panel__search input:focus-visible {
      outline: 2px solid Highlight;
      outline-offset: 2px;
    }
  }

  .filter-panel__footer {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.625rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: 1rem;
    margin-top: auto;
  }
  #filter-results {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  #filter-reset {
    width: 100%;
    min-height: 44px;
    padding: 0.5rem 1.125rem;
    background: transparent;
    color: var(--color-terracotta);
    border: 1px solid var(--color-terracotta);
    border-radius: 999px;
    font: inherit;
    font-weight: 500;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  #filter-reset:hover {
    background: var(--color-terracotta);
    color: white;
  }
  #filter-reset:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
</style>
